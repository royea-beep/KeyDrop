generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  businessName String?  @map("business_name")
  logoUrl      String?  @map("logo_url")
  language     String   @default("en")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  requests CredentialRequest[]

  @@map("users")
}

model CredentialRequest {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  clientName  String    @map("client_name")
  clientEmail String?   @map("client_email")
  clientPhone String?   @map("client_phone")
  projectName String?   @map("project_name")
  note        String?
  language    String    @default("en")
  token       String    @unique
  status      String    @default("PENDING")
  expiresAt   DateTime  @map("expires_at")
  maxViews    Int       @default(1) @map("max_views")
  viewCount   Int       @default(0) @map("view_count")
  submittedAt DateTime? @map("submitted_at")
  retrievedAt DateTime? @map("retrieved_at")
  revokedAt   DateTime? @map("revoked_at")
  submitterIp String?   @map("submitter_ip")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  fields           CredentialField[]
  oauthConnections OAuthConnection[]
  auditLogs        AuditLog[]

  @@index([token])
  @@index([userId, status])
  @@index([expiresAt])
  @@map("credential_requests")
}

model CredentialField {
  id                String    @id @default(uuid())
  requestId         String    @map("request_id")
  request           CredentialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  label             String
  fieldType         String    @default("TEXT") @map("field_type")
  required          Boolean   @default(true)
  sortOrder         Int       @default(0) @map("sort_order")
  placeholder       String?
  hint              String?
  validationPattern String?   @map("validation_pattern")
  encryptedValue    String?   @map("encrypted_value")
  iv                String?
  authTag           String?   @map("auth_tag")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([requestId])
  @@map("credential_fields")
}

model OAuthConnection {
  id               String    @id @default(uuid())
  requestId        String    @map("request_id")
  request          CredentialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  provider         String
  providerLabel    String    @map("provider_label")
  scopes           String?
  encryptedToken   String?   @map("encrypted_token")
  iv               String?
  authTag          String?   @map("auth_tag")
  tokenType        String?   @map("token_type")
  expiresAt        DateTime? @map("expires_at")
  refreshEncrypted String?   @map("refresh_encrypted")
  refreshIv        String?   @map("refresh_iv")
  refreshAuthTag   String?   @map("refresh_auth_tag")
  connectedAt      DateTime? @map("connected_at")
  accountName      String?   @map("account_name")
  accountId        String?   @map("account_id")
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([requestId])
  @@map("oauth_connections")
}

model ServiceTemplate {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  icon             String?
  category         String
  authMethod       String   @default("MANUAL") @map("auth_method")
  oauthProvider    String?  @map("oauth_provider")
  oauthScopes      String?  @map("oauth_scopes")
  fields           String
  guide            String?
  validationRules  String?  @map("validation_rules")
  stuckCount       Int      @default(0) @map("stuck_count")
  successCount     Int      @default(0) @map("success_count")
  avgCompletionSec Float?   @map("avg_completion_sec")
  isBuiltIn        Boolean  @default(true) @map("is_built_in")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("service_templates")
}

model AuditLog {
  id        String             @id @default(uuid())
  requestId String?            @map("request_id")
  request   CredentialRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  userId    String?            @map("user_id")
  action    String
  ipAddress String?            @map("ip_address")
  userAgent String?            @map("user_agent")
  metadata  String?
  createdAt DateTime           @default(now()) @map("created_at")

  @@index([requestId])
  @@index([userId])
  @@map("audit_logs")
}
