generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  businessName String?  @map("business_name")
  logoUrl      String?  @map("logo_url")
  language     String   @default("en")

  // Stripe billing
  plan                String   @default("FREE")
  stripeCustomerId    String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  subscriptionStatus  String   @default("INACTIVE") @map("subscription_status")
  currentPeriodEnd    DateTime? @map("current_period_end")
  requestsThisMonth   Int      @default(0) @map("requests_this_month")
  billingCycleStart   DateTime @default(now()) @map("billing_cycle_start")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  requests      CredentialRequest[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model CredentialRequest {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  clientName  String    @map("client_name")
  clientEmail String?   @map("client_email")
  clientPhone String?   @map("client_phone")
  projectName String?   @map("project_name")
  note        String?
  language    String    @default("en")
  token       String    @unique
  status      String    @default("PENDING")
  expiresAt   DateTime  @map("expires_at")
  maxViews    Int       @default(1) @map("max_views")
  viewCount   Int       @default(0) @map("view_count")
  submittedAt DateTime? @map("submitted_at")
  retrievedAt DateTime? @map("retrieved_at")
  revokedAt   DateTime? @map("revoked_at")
  templateSlug String?   @map("template_slug")
  submitterIp  String?   @map("submitter_ip")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  fields           CredentialField[]
  oauthConnections OAuthConnection[]
  auditLogs        AuditLog[]

  @@index([token])
  @@index([userId, status])
  @@index([expiresAt])
  @@map("credential_requests")
}

model CredentialField {
  id                String    @id @default(uuid())
  requestId         String    @map("request_id")
  request           CredentialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  label             String
  fieldType         String    @default("TEXT") @map("field_type")
  required          Boolean   @default(true)
  sortOrder         Int       @default(0) @map("sort_order")
  placeholder       String?
  hint              String?
  validationPattern String?   @map("validation_pattern")
  encryptedValue    String?   @map("encrypted_value")
  iv                String?
  authTag           String?   @map("auth_tag")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([requestId])
  @@map("credential_fields")
}

model OAuthConnection {
  id               String    @id @default(uuid())
  requestId        String    @map("request_id")
  request          CredentialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  provider         String
  providerLabel    String    @map("provider_label")
  scopes           String?
  encryptedToken   String?   @map("encrypted_token")
  iv               String?
  authTag          String?   @map("auth_tag")
  tokenType        String?   @map("token_type")
  expiresAt        DateTime? @map("expires_at")
  refreshEncrypted String?   @map("refresh_encrypted")
  refreshIv        String?   @map("refresh_iv")
  refreshAuthTag   String?   @map("refresh_auth_tag")
  connectedAt      DateTime? @map("connected_at")
  accountName      String?   @map("account_name")
  accountId        String?   @map("account_id")
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([requestId])
  @@map("oauth_connections")
}

model AuditLog {
  id        String             @id @default(uuid())
  requestId String?            @map("request_id")
  request   CredentialRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  userId    String?            @map("user_id")
  action    String
  ipAddress String?            @map("ip_address")
  userAgent String?            @map("user_agent")
  metadata  String?
  createdAt DateTime           @default(now()) @map("created_at")

  @@index([requestId])
  @@index([userId])
  @@map("audit_logs")
}
