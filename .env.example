# Database — SQLite for local dev, Neon Postgres for Vercel
# Local:  file:./dev.db
# Vercel: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=file:./dev.db

# 32-byte hex key for AES-256-GCM encryption of stored credentials
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=

# JWT signing secrets (generate with: openssl rand -hex 32)
JWT_SECRET=
JWT_REFRESH_SECRET=

# App URL (used for checkout redirect and webhook verification)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LemonSqueezy billing (https://app.lemonsqueezy.com)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_STORE_SLUG=
LEMONSQUEEZY_WEBHOOK_SECRET=

# LemonSqueezy plan variant IDs (from Products → Variants in LS dashboard)
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_TEAM_VARIANT_ID=
